# Copy this file to .env and fill in real values. Never commit the real .env.

PORT=5000

# Your MongoDB Atlas connection string
MONGO_URI=

# Any long random string — used to sign auth tokens
JWT_SECRET=

# From Google Cloud Console -> APIs & Services -> Credentials
# (OAuth client of type "Web application")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Your deployed frontend URL, once you have one (leave blank for local dev)
CLIENT_URL=
